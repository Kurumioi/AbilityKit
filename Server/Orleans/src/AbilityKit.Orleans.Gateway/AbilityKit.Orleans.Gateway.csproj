<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);CS8714;CS8765;CS8767;CS8600;CS8602;CS8604;CS8618;CS8622;CS8625</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.gameframework\Runtime\GameFramework\**\*.cs" Exclude="..\..\..\..\Unity\Packages\com.abilitykit.gameframework\Runtime\GameFramework\Properties\AssemblyInfo.cs" Link="GameFramework\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AbilityKit.Orleans.Contracts\AbilityKit.Orleans.Contracts.csproj" />
    <ProjectReference Include="..\..\..\..\src\AbilityKit.Network.Runtime\AbilityKit.Network.Runtime.csproj" />
    <ProjectReference Include="..\..\..\..\src\AbilityKit.Protocol.Moba\AbilityKit.Protocol.Moba.csproj" />
    <ProjectReference Include="..\..\..\..\src\AbilityKit.Protocol.Room\AbilityKit.Protocol.Room.csproj" />
    <ProjectReference Include="..\..\..\..\src\AbilityKit.World.StateSync\AbilityKit.World.StateSync.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MemoryPack" Version="1.21.4" />
    <PackageReference Include="Microsoft.Orleans.Client" Version="8.0.0" />
    <PackageReference Include="Microsoft.Orleans.Sdk" Version="8.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
