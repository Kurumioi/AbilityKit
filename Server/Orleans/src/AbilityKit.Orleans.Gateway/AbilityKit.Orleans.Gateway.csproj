<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);CS8714;CS8765;CS8767;CS8600;CS8602;CS8604;CS8618;CS8622;CS8625</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.world.statesync\Runtime\**\*.cs" Exclude="..\..\..\..\Unity\Packages\com.abilitykit.world.statesync\Runtime\**\*.asmdef" />
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.protocol.moba\Runtime\StateSync\*.cs" Link="Protocol.Moba\StateSync\%(Filename)%(Extension)" />
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.protocol.moba\Runtime\GatewayTimeSync\*.cs" Link="Protocol.Moba\GatewayTimeSync\%(Filename)%(Extension)" />
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.protocol.moba\Runtime\Generated\**\*.cs" Link="Protocol.Moba.Generated\%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.gameframework\Runtime\GameFramework\**\*.cs" Exclude="..\..\..\..\Unity\Packages\com.abilitykit.gameframework\Runtime\GameFramework\Properties\AssemblyInfo.cs" Link="GameFramework\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AbilityKit.Orleans.Contracts\AbilityKit.Orleans.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MemoryPack" Version="1.21.4" />
    <PackageReference Include="Microsoft.Orleans.Client" Version="8.0.0" />
    <PackageReference Include="Microsoft.Orleans.Sdk" Version="8.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
