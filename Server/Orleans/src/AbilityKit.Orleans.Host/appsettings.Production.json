{
  "AbilityKit": {
    "Orleans": {
      "ClusterId": "abilitykit-prod",
      "ServiceId": "abilitykit-orleans"
    },
    "Logging": {
      "MinimumLevel": "Information",
      "MicrosoftLevel": "Warning",
      "HostingLifetimeLevel": "Information",
      "OrleansLevel": "Warning",
      "ApplicationLevel": "Information"
    },
    "Storage": {
      "Provider": "External",
      "SessionStateProvider": "External",
      "RoomStateProvider": "External",
      "Required": true,
      "ConnectionStringName": "AbilityKitStorage",
      "AllowInMemoryFallbackForUnsupportedProviders": true
    },
    "Deployment": {
      "Role": "Shared",
      "Groups": [ "session", "room", "battle" ],
      "Affinity": [ "Session", "Room", "Battle" ],
      "TargetSiloCount": 1,
      "MaxRoomsPerSilo": 500,
      "MaxBattlesPerSilo": 200,
      "MaxSessionsPerGateway": 5000,
      "Mode": {
        "Mode": "Shared",
        "PreferSharedDuringDevelopment": true,
        "ForceDedicatedRolesInProduction": false,
        "EnabledRoles": [ "Shared", "Session", "Room", "Battle" ]
      },
      "SiloRole": {
        "Role": "Shared",
        "IsGateway": false,
        "IsExclusive": false,
        "LogicalGroups": [ "session", "room", "battle" ]
      },
      "RuntimeProfile": {
        "Role": "Shared",
        "LogicalGroups": [ "session", "room", "battle" ],
        "PreferredAffinity": [ "Session", "Room", "Battle" ],
        "IsExclusive": false,
        "IsGateway": false,
        "MaxRooms": 500,
        "MaxBattles": 200,
        "MaxSessions": 5000,
        "Notes": "Production-ready role split is declared here; localhost clustering remains the development/runtime default until external membership is enabled."
      }
    }
  }
}
