{
  "AbilityKit": {
    "Orleans": {
      "ClusterId": "abilitykit-dev",
      "ServiceId": "abilitykit-orleans",
      "SiloPort": 11111,
      "GatewayPort": 30000
    },
    "Logging": {
      "MinimumLevel": "Information",
      "IncludeScopes": true,
      "SingleLine": true,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff ",
      "MicrosoftLevel": "Warning",
      "HostingLifetimeLevel": "Information",
      "OrleansLevel": "Information",
      "ApplicationLevel": "Information"
    },
    "Storage": {
      "Provider": "None",
      "SessionStateProvider": "InMemory",
      "RoomStateProvider": "InMemory",
      "Required": false
    },
    "StateSyncObserver": {
      "BytesPerSecond": 16384,
      "BurstBytes": 32768,
      "MaxQueueLength": 32,
      "MaxQueueAgeMs": 500,
      "DrainIntervalMs": 10
    },
    "BattleInputSecurity": {
      "MaxPayloadBytes": 4096,
      "MaxOpCode": 65535,
      "ReplayWindowSize": 128,
      "InputsPerSecond": 60,
      "BurstInputs": 90,
      "MaxGatewayTrackedKeys": 4096,
      "MaxBattleTrackedPlayers": 256,
      "GatewayIdleStateTtlSeconds": 300
    }
  }
}
