### 3.3 逻辑层 - 完整计算

```csharp
/// <summary>
/// 逻辑层服务示例
/// 负责所有计算，发布完整的事件
/// </summary>
public sealed class MobaEffectExecutionService
{
    public void Execute(int effectId, IAbilityPipelineContext context)
    {
        // ✅ 正确：在逻辑层计算所有数值
        var damage = CalculateDamage(caster, target, skillLevel);
        var finalDamage = ApplyArmorReduction(damage, targetArmor);
        var newHp = Math.Max(0, target.Hp - finalDamage);
        var isDead = newHp <= 0;

        // ✅ 正确：发布完整的事件
        var damageData = new DamageEventData(
            casterId: caster.Id,
            targetId: target.Id,
            damageType: skillDamageType,
            damageValue: finalDamage,        // 完整计算后的伤害
            targetHpAfter: newHp,           // 计算后的 HP
            maxHp: target.MaxHp,
            isDead: isDead);                // 死亡判定结果

        _snapshotDispatcher.DispatchDamageEvent(currentFrame, new[] { damageData });
    }
}
```

