### 17.3 ETUnitExtensions 扩展方法

```csharp
/// <summary>
/// ETUnit 扩展方法
/// 提供子组件访问和便捷属性
/// Design:
/// - Component 只存储数据（这里是子组件 ID），不持有 Component 引用
/// - 通过 GetChild<T>(id) 获取子组件，保持 O(1) 查找性能
/// </summary>
public static class ETUnitExtensions
{
    #region Child Component Access

    public static ETUnitMetaComponent? GetMeta(this ETUnit self)
    {
        if (self.MetaId == 0)
            return null;
        return self.GetChild<ETUnitMetaComponent>(self.MetaId);
    }

    public static ETUnitTransformComponent? GetTransform(this ETUnit self)
    {
        if (self.TransformId == 0)
            return null;
        return self.GetChild<ETUnitTransformComponent>(self.TransformId);
    }

    public static ETUnitCharacterComponent? GetCharacter(this ETUnit self)
    {
        if (self.CharacterId == 0)
            return null;
        return self.GetChild<ETUnitCharacterComponent>(self.CharacterId);
    }

    // ... 其他子组件访问方法

    #endregion

    #region Convenience Properties

    public static int GetEntityCode(this ETUnit self) =>
        self.GetMeta()?.EntityCode ?? 0;

    public static float GetX(this ETUnit self) =>
        self.GetTransform()?.X ?? 0;

    public static float GetHp(this ETUnit self) =>
        self.GetCharacter()?.Hp ?? 0;

    public static bool IsDead(this ETUnit self) =>
        self.GetCharacter()?.IsDead ?? true;

    #endregion

    #region Setters

    public static void SetHp(this ETUnit self, float hp)
    {
        self.GetCharacter()?.SetHp(hp);
    }

    public static void SetTarget(this ETUnit self, float x, float y)
    {
        self.GetTransform()?.SetTarget(x, y);
    }

    #endregion
}
```

### 17.4 子组件访问规范

```csharp
// ✅ 正确：通过扩展方法访问
var hp = unit.GetHp();
var x = unit.GetX();
unit.SetTarget(10f, 20f);

// ✅ 正确：安全访问子组件
var transform = unit.GetTransform();
if (transform != null)
{
    var rotation = transform.Rotation;
}

// ❌ 错误：直接访问私有字段
var hp = unit._character.Hp; // ❌

// ❌ 错误：在构造时缓存引用
public class ETUnit : Entity
{
    private ETUnitCharacterComponent _character; // ❌
}
```

### 17.5 子组件创建流程

```csharp
// 在 ETUnitComponentSystem.CreateUnit 中
public static ETUnit CreateUnit(this ETUnitComponent self, /* ... */)
{
    var unit = self.AddChild<ETUnit>();

    // 创建子组件
    var meta = unit.AddChild<ETUnitMetaComponent>();
    var transform = unit.AddChild<ETUnitTransformComponent>();
    var character = unit.AddChild<ETUnitCharacterComponent>();
    var skillList = unit.AddChild<ETUnitSkillListComponent>();
    var buffList = unit.AddChild<ETUnitBuffListComponent>();

    // 存储子组件 ID
    unit.MetaId = meta.Id;
    unit.TransformId = transform.Id;
    unit.CharacterId = character.Id;
    unit.SkillListId = skillList.Id;
    unit.BuffListId = buffList.Id;

    return unit;
}
```

