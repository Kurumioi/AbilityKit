{
  "$schema": "abilitykit-trigger-source-v1",
  "version": "1.0",
  "metadata": {
    "author": "team",
    "created_at": "2026-05-01T10:00:00Z",
    "last_modified": "2026-05-01T10:00:00Z",
    "description": "触发器源配置（可直接编辑）"
  },
  "variables": [
    { "name": "$caster", "description": "技能释放者" },
    { "name": "$target", "description": "目标实体" },
    { "name": "$self", "description": "触发者自身" }
  ],
  "actions": {
    "debug_log": {
      "type": "debug_log",
      "displayName": "调试日志",
      "description": "输出调试信息到控制台",
      "category": "调试",
      "params": [
        { "name": "message", "type": "string", "required": true },
        { "name": "dump_args", "type": "bool", "required": false, "defaultValue": false }
      ]
    },
    "shoot_projectile": {
      "type": "shoot_projectile",
      "displayName": "发射弹道",
      "description": "从发射者向目标发射弹道",
      "category": "战斗",
      "params": [
        { "name": "launcher", "type": "entity", "required": true },
        { "name": "target", "type": "entity", "required": true },
        { "name": "projectile_id", "type": "int", "required": true },
        { "name": "speed", "type": "float", "required": false, "defaultValue": 300.0 }
      ]
    },
    "give_damage": {
      "type": "give_damage",
      "displayName": "造成伤害",
      "description": "对目标造成伤害",
      "category": "战斗",
      "params": [
        { "name": "from", "type": "entity", "required": true },
        { "name": "to", "type": "entity", "required": true },
        { "name": "amount", "type": "expr", "required": true },
        { "name": "reason", "type": "int", "required": false, "defaultValue": 0 }
      ]
    },
    "add_buff": {
      "type": "add_buff",
      "displayName": "添加Buff",
      "description": "为目标添加Buff效果",
      "category": "Buff",
      "params": [
        { "name": "target", "type": "entity", "required": true },
        { "name": "buff_id", "type": "int", "required": true },
        { "name": "duration", "type": "float", "required": false, "defaultValue": -1.0 }
      ]
    },
    "seq": {
      "type": "seq",
      "displayName": "顺序执行",
      "description": "按顺序执行多个动作",
      "category": "流程",
      "isComposite": true,
      "params": [
        { "name": "items", "type": "action[]", "required": true }
      ]
    }
  },
  "conditions": {
    "all": {
      "type": "all",
      "displayName": "全部满足",
      "description": "所有子条件都必须满足",
      "category": "复合",
      "isComposite": true,
      "params": [
        { "name": "items", "type": "condition[]", "required": true }
      ]
    },
    "any": {
      "type": "any",
      "displayName": "任一满足",
      "description": "任一子条件满足即可",
      "category": "复合",
      "isComposite": true,
      "params": [
        { "name": "items", "type": "condition[]", "required": true }
      ]
    },
    "not": {
      "type": "not",
      "displayName": "取反",
      "description": "对子条件取反",
      "category": "复合",
      "isComposite": true,
      "params": [
        { "name": "item", "type": "condition", "required": true }
      ]
    },
    "arg_eq": {
      "type": "arg_eq",
      "displayName": "参数等于",
      "description": "检查参数值是否等于指定值",
      "category": "参数",
      "params": [
        { "name": "arg_name", "type": "string", "required": true },
        { "name": "value", "type": "number", "required": true }
      ]
    },
    "arg_gt": {
      "type": "arg_gt",
      "displayName": "参数大于",
      "description": "检查参数值是否大于指定值",
      "category": "参数",
      "params": [
        { "name": "arg_name", "type": "string", "required": true },
        { "name": "value", "type": "number", "required": true }
      ]
    }
  },
  "triggers": [
    {
      "id": 10001,
      "name": "普攻发射弹道",
      "event": "attack.hit",
      "priority": 100,
      "phase": "immediate",
      "enabled": true,
      "allowExternal": false,
      "comment": "当普攻命中时发射弹道",
      "conditions": [],
      "actions": [
        {
          "type": "debug_log",
          "message": "普攻命中，发射弹道"
        },
        {
          "type": "shoot_projectile",
          "launcher": "$caster",
          "target": "$target",
          "projectile_id": 200001,
          "speed": 600
        }
      ]
    },
    {
      "id": 10002,
      "name": "技能造成伤害",
      "event": "skill.cast.complete",
      "priority": 50,
      "phase": "immediate",
      "enabled": true,
      "conditions": [
        {
          "type": "arg_gt",
          "arg_name": "skill_level",
          "value": 0
        }
      ],
      "actions": [
        {
          "type": "give_damage",
          "from": "$caster",
          "to": "$target",
          "amount": "=$caster.attack * 1.5 + $caster.skill_power * 0.5",
          "reason": 1
        }
      ]
    },
    {
      "id": 10003,
      "name": "添加灼烧Buff",
      "event": "buff.applied",
      "priority": 0,
      "phase": "immediate",
      "enabled": true,
      "conditions": [
        {
          "type": "all",
          "items": [
            { "type": "arg_eq", "arg_name": "buff_id", "value": 2001 },
            { "type": "arg_gt", "arg_name": "stack", "value": 3 }
          ]
        }
      ],
      "actions": [
        {
          "type": "add_buff",
          "target": "$target",
          "buff_id": 3001,
          "duration": 5.0
        }
      ]
    }
  ]
}
