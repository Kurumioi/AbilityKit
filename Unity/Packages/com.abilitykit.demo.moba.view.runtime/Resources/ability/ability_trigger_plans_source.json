{
  "$schema": "abilitykit-trigger-source-v1",
  "version": 1,
  "description": "MOBA demo readable trigger source. Human-authored actions use readable type names and are compiled to runtime ActionId values by the trigger source exporter.",
  "actions": {
    "debug_log": {
      "type": "debug_log",
      "displayName": "调试日志",
      "category": "Debug",
      "params": [
        { "name": "message", "type": "string", "required": true },
        { "name": "dump_args", "type": "bool", "required": false, "defaultValue": false }
      ]
    },
    "shoot_projectile": {
      "type": "shoot_projectile",
      "displayName": "发射弹道",
      "category": "Combat",
      "params": [
        { "name": "launcher_id", "type": "int", "required": true },
        { "name": "projectile_id", "type": "int", "required": true },
        { "name": "targetCode", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "directionSource", "type": "string", "required": false, "defaultValue": "cast_context" }
      ]
    },
    "spawn_area": {
      "type": "spawn_area",
      "displayName": "生成区域",
      "category": "Combat",
      "params": [
        { "name": "area_id", "type": "int", "required": true },
        { "name": "position_mode", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "radius", "type": "float", "required": false, "defaultValue": 0 },
        { "name": "duration_ms", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "duration_frames", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "stay_interval_frames", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "collision_layer_mask", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "offset_x", "type": "float", "required": false, "defaultValue": 0 },
        { "name": "offset_y", "type": "float", "required": false, "defaultValue": 0 },
        { "name": "offset_z", "type": "float", "required": false, "defaultValue": 0 }
      ]
    },
    "give_damage": {
      "type": "give_damage",
      "displayName": "造成伤害",
      "category": "Combat",
      "params": [
        { "name": "damage_value", "type": "float", "required": true },
        { "name": "damage_type", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "reason_param", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "target_query_id", "type": "int", "required": false, "defaultValue": 0 }
      ]
    },
    "add_buff": {
      "type": "add_buff",
      "displayName": "添加Buff",
      "category": "Buff",
      "params": [
        { "name": "buffIds", "type": "int[]", "required": true },
        { "name": "targetCode", "type": "int", "required": true }
      ]
    },
    "dash": {
      "type": "dash",
      "displayName": "冲刺位移",
      "category": "Motion",
      "params": [
        { "name": "speed", "type": "float", "required": true },
        { "name": "duration_ms", "type": "int", "required": true },
        { "name": "direction_mode", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "apply_to_caster", "type": "bool", "required": false, "defaultValue": true },
        { "name": "priority", "type": "int", "required": false, "defaultValue": 10 }
      ]
    },
    "pull": {
      "type": "pull",
      "displayName": "牵引/击飞位移",
      "category": "Motion",
      "params": [
        { "name": "speed", "type": "float", "required": true },
        { "name": "duration_ms", "type": "int", "required": true },
        { "name": "direction_mode", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "target_distance", "type": "float", "required": false, "defaultValue": 0 },
        { "name": "priority", "type": "int", "required": false, "defaultValue": 12 }
      ]
    },
    "add_shield": {
      "type": "add_shield",
      "displayName": "添加护盾",
      "category": "Buff",
      "params": [
        { "name": "shield_id", "type": "int", "required": true },
        { "name": "shield_value", "type": "float", "required": true },
        { "name": "duration_ms", "type": "int", "required": true },
        { "name": "absorb_ratio", "type": "float", "required": false, "defaultValue": 1 },
        { "name": "target_self", "type": "bool", "required": false, "defaultValue": false }
      ]
    },
    "modify_resource": {
      "type": "modify_resource",
      "displayName": "修改资源",
      "category": "Resource",
      "params": [
        { "name": "resource_type", "type": "int", "required": true },
        { "name": "amount", "type": "float", "required": true },
        { "name": "min", "type": "float", "required": false },
        { "name": "max", "type": "float", "required": false },
        { "name": "target_self", "type": "bool", "required": false, "defaultValue": false },
        { "name": "target_payload_field", "type": "string", "required": false }
      ]
    },
    "convert_resource_to_heal": {
      "type": "convert_resource_to_heal",
      "displayName": "资源转治疗",
      "category": "Resource",
      "params": [
        { "name": "resource_type", "type": "int", "required": true },
        { "name": "amount", "type": "float", "required": true },
        { "name": "heal_ratio", "type": "float", "required": false, "defaultValue": 1 },
        { "name": "out_of_combat_seconds", "type": "float", "required": false, "defaultValue": 0 },
        { "name": "heal_type", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "reason_kind", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "reason_param", "type": "int", "required": false, "defaultValue": 0 },
        { "name": "target_self", "type": "bool", "required": false, "defaultValue": false }
      ]
    }
  },
