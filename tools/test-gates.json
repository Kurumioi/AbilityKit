    },
    {
      "name": "moba-daji-unity",
      "level": "P2",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Daji Unity EditMode hero acceptance fixture as a scheduled regression baseline.",
      "scope": [
        "unity-editmode",
        "moba-hero-acceptance",
        "moba-daji",
        "scene-contracts",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
        "broad-moba-hero-refactor-completion",
        "release-candidate",
        "batch-merge"
      ],
      "failurePolicy": "Treat as a P2 release and batch-merge blocker. Preserve matching Unity command, log, and NUnit XML artifacts for triage.",
      "ciPolicy": {
