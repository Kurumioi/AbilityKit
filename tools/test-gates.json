{
  "schemaVersion": 5,
  "owner": "AbilityKit Engineering",
  "defaultGate": "precheck",
  "documentation": "Docs/AbilityKit测试门禁与批量回归规范.md",
  "ci": {
    "workflow": ".github/workflows/abilitykit-test-gates.yml",
    "artifactRoot": "artifacts/test-gates",
    "pullRequestGate": "precheck",
    "manualDefaultGate": "regression",
    "scheduledGate": "regression",
    "scheduledCronUtc": "0 18 * * *",
    "scheduledCronDescription": "Daily 02:00 Asia/Shanghai regression baseline."
  },
  "policies": {
    "P0": {
      "name": "Development Blocker",
      "rule": "Must pass before continuing feature development or submitting related changes."
    },
    "P1": {
      "name": "Contract Blocker",
      "rule": "Must pass after runtime contract, networking, DI, or presentation-runtime boundary changes."
    },
    "P2": {
      "name": "Regression Baseline",
      "rule": "Must pass before broad refactors, release candidates, or batch merges."
    }
  },
  "gates": [
    {
      "name": "precheck",
      "level": "P0",
      "owner": "Core/MOBA Runtime",
      "description": "Fast local gate before continuing feature development.",
      "scope": [
        "local-development",
        "moba-console",
        "battle-entry"
      ],
      "requiredBefore": [
        "continue-feature-development",
        "commit-related-runtime-or-console-changes"
      ],
      "failurePolicy": "Stop new feature work immediately. Fix the failing build or smoke test first.",
      "ciPolicy": {
        "runOnPullRequest": true,
        "runOnPush": true,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Build moba console",
          "kind": "dotnet-build",
          "project": "src/AbilityKit.Demo.Moba.Console/AbilityKit.Demo.Moba.Console.csproj"
        },
        {
          "name": "Moba console smoke gate",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Demo.Moba.Tests/AbilityKit.Demo.Moba.Tests.csproj",
          "filter": "Gate=MobaConsoleSmoke"
        }
      ]
    },
    {
      "name": "moba-console-smoke",
      "level": "P0",
      "owner": "MOBA Runtime/Presentation",
      "description": "MOBA console smoke tests that must pass before presentation/runtime follow-up work.",
      "scope": [
        "moba-console",
        "presentation-testability",
        "battle-runtime-smoke",
        "skill-cast-trace"
      ],
      "requiredBefore": [
        "continue-moba-presentation-work",
        "change-console-battle-entry",
        "change-runtime-input-or-view-timeline-path"
      ],
      "failurePolicy": "Block follow-up MOBA presentation/runtime changes until the smoke path passes.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Moba console smoke gate",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Demo.Moba.Tests/AbilityKit.Demo.Moba.Tests.csproj",
          "filter": "Gate=MobaConsoleSmoke"
        }
      ]
    },
    {
      "name": "runtime-contracts",
      "level": "P1",
      "owner": "Runtime Platform",
      "description": "Core pure-C# runtime contract tests for networking, DI and shared presentation runtime.",
      "scope": [
        "network-runtime",
        "world-di",
        "game-view-runtime-contracts"
      ],
      "requiredBefore": [
        "merge-runtime-contract-change",
        "continue-after-network-di-or-view-runtime-boundary-change"
      ],
      "failurePolicy": "Fix contract breakage or explicitly update the design document before continuing dependent work.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Network runtime tests",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Network.Runtime.Tests/AbilityKit.Network.Runtime.Tests.csproj"
        },
        {
          "name": "World DI tests",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.World.DI.Tests/AbilityKit.World.DI.Tests.csproj"
        },
        {
          "name": "Game view runtime tests",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Game.View.Runtime.Tests/AbilityKit.Game.View.Runtime.Tests.csproj"
        }
      ]
    },
    {
      "name": "regression",
      "level": "P2",
      "owner": "AbilityKit Engineering",
      "description": "Batch regression gate for the main pure-C# test projects used before broad refactors or merges.",
      "scope": [
        "batch-regression",
        "moba-runtime",
        "moba-view-runtime",
        "shooter-runtime",
        "runtime-contracts"
      ],
      "requiredBefore": [
        "broad-refactor-completion",
        "release-candidate",
        "batch-merge"
      ],
      "failurePolicy": "Treat as release or merge blocker. Triage by failing project and add/adjust smaller gates if needed.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": true,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Moba console smoke gate",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Demo.Moba.Tests/AbilityKit.Demo.Moba.Tests.csproj",
          "filter": "Gate=MobaConsoleSmoke"
        },
        {
          "name": "Moba view runtime tests",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Demo.Moba.View.Runtime.Tests/AbilityKit.Demo.Moba.View.Runtime.Tests.csproj"
        },
        {
          "name": "Shooter runtime tests",
          "kind": "dotnet-test",
          "project": "src/AbilityKit.Demo.Shooter.Runtime.Tests/AbilityKit.Demo.Shooter.Runtime.Tests.csproj"
        },
        {
          "name": "Runtime contracts",
          "kind": "gate",
          "gate": "runtime-contracts"
        },
        {
          "name": "Zhao Yun Unity acceptance",
          "kind": "gate",
          "gate": "moba-zhaoyun-unity"
        },
        {
          "name": "Mozi Unity acceptance",
          "kind": "gate",
          "gate": "moba-mozi-unity"
        },
        {
          "name": "Daji Unity acceptance",
          "kind": "gate",
          "gate": "moba-daji-unity"
        },
        {
          "name": "Ying Zheng Unity acceptance",
          "kind": "gate",
          "gate": "moba-yingzheng-unity"
        }
      ]
    },
    {
      "name": "moba-content-contracts",
      "level": "P1",
      "owner": "MOBA Content Pipeline",
      "description": "Run MOBA content contracts for package resource ownership, business ID governance, trigger aggregate drift, configured presentation resources, and effective timing validation.",
      "scope": [
        "unity-editmode",
        "moba-content-pipeline",
        "resource-ownership",
        "business-id-governance",
        "config-validation"
      ],
      "requiredBefore": [
        "publish-moba-content",
        "merge-moba-config-or-resource-changes"
      ],
      "failurePolicy": "Block MOBA content publication until resource ownership, business ID governance, aggregate drift, configured resources, and effective timing contracts pass.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "MOBA hero acceptance coverage manifest",
          "kind": "powershell-script",
          "script": "tools/validate_moba_hero_acceptance_coverage.ps1"
        },
        {
          "name": "MOBA business ID governance tests",
          "kind": "powershell-script",
          "script": "tools/moba_business_id.tests.ps1"
        },
        {
          "name": "MOBA authoritative business IDs",
          "kind": "powershell-script",
          "script": "tools/moba_business_id.ps1",
          "arguments": [
            "-Mode",
            "Validate"
          ]
        },
        {
          "name": "MOBA package resource ownership",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.BattleTestScriptRunnerEditModeTests.MobaTriggerResources_AreOwnedByViewRuntimePackage"
        },
        {
          "name": "MOBA canonical trigger aggregate",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "MobaTriggerPlanAggregateTests"
        },
        {
          "name": "MOBA configured presentation resources",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.MobaPresentationResourceTests"
        },
        {
          "name": "MOBA effective spawn area timing",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.MobaSpawnAreaEffectiveTimingValidationTests"
        }
      ]
    },
    {
      "name": "moba-xiaoqiao-unity",
      "level": "P1",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Xiao Qiao Unity EditMode behavior and presentation-resource tests and persist matching command, log, and NUnit XML artifacts.",
      "scope": [
        "unity-editmode",
        "moba-xiaoqiao",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
        "claim-latest-xiaoqiao-unity-result",
        "close-xiaoqiao-skill-contract-regression"
      ],
      "failurePolicy": "Do not claim the latest Xiao Qiao Unity result until the executed Xiao Qiao EditMode batch has matching XML result files in the gate output directory.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Xiao Qiao Unity presentation resources authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.XiaoQiaoPresentationResources_ShouldLoadAndMatchUltimateRadius"
        },
        {
          "name": "Xiao Qiao Unity Skill10020101 authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.Skill10020101_ScenarioExportsTraceAndConfirmsProjectileDamage"
        },
        {
          "name": "Xiao Qiao Unity Skill10020201 authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.Skill10020201_ScenarioExportsTraceAndConfirmsAreaDamage"
        },
        {
          "name": "Xiao Qiao Unity Skill10020301 authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.Skill10020301_ScenarioExportsTraceAndConfirmsIntervalDamage"
        },
        {
          "name": "Xiao Qiao Unity Skill10020000 passive authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.Skill10020000_PassiveCastBuff_ShouldIncreaseMoveSpeedTemporarily"
        },
        {
          "name": "Xiao Qiao Unity Skill10020000 passive refresh authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.XiaoQiaoSkillAcceptanceTests.Skill10020000_PassiveCastBuff_RepeatedCastShouldRefreshDurationFromLatestApply"
        }
      ]
    },
    {
      "name": "moba-lianpo-unity",
      "level": "P1",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Lian Po Unity EditMode scenario tests and persist matching command, log, and NUnit XML artifacts.",
      "scope": [
        "unity-editmode",
        "moba-lianpo",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
        "claim-latest-lianpo-unity-result",
        "close-lianpo-skill-contract-regression"
      ],
      "failurePolicy": "Do not claim the latest Lian Po Unity result until the executed scenario-test batch has matching XML result files in the gate output directory.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": false,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Lian Po Unity Skill10010201 authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.LianPoSkillAcceptanceTests.Skill10010201_ScenarioExportsTraceAndConfirmsShieldAreaDamageAndSlow"
        },
        {
          "name": "Lian Po Unity Skill10010301 authoritative",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.LianPoSkillAcceptanceTests.Skill10010301_ScenarioExportsTraceAndConfirmsThirdStageKnockup"
        }
      ]
    },
    {
      "name": "moba-zhaoyun-unity",
      "level": "P2",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Zhao Yun Unity EditMode hero acceptance fixture as a scheduled regression baseline.",
      "scope": [
        "unity-editmode",
        "moba-hero-acceptance",
        "moba-zhaoyun",
        "scene-contracts",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
        "broad-moba-hero-refactor-completion",
        "release-candidate",
        "batch-merge"
      ],
      "failurePolicy": "Treat as a P2 release and batch-merge blocker. Preserve matching Unity command, log, and NUnit XML artifacts for triage.",
      "ciPolicy": {
        "runOnPullRequest": false,
        "runOnPush": false,
        "runOnSchedule": true,
        "artifactRequired": true
      },
      "steps": [
        {
          "name": "Zhao Yun Unity acceptance fixture",
          "kind": "unity-editmode-test",
          "projectPath": "Unity",
          "testPlatform": "EditMode",
          "testFilter": "AbilityKit.Game.Test.UnitTest.ZhaoYunSkillAcceptanceTests"
        }
      ]
    },
    {
      "name": "moba-mozi-unity",
      "level": "P2",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Mozi Unity EditMode hero acceptance fixture as a scheduled regression baseline.",
      "scope": [
        "unity-editmode",
        "moba-hero-acceptance",
        "moba-mozi",
        "scene-contracts",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
        "broad-moba-hero-refactor-completion",
