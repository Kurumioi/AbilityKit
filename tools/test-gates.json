        }
      ]
    },
    {
      "name": "moba-yingzheng-unity",
      "level": "P2",
      "owner": "MOBA Runtime/Unity Test",
      "description": "Run the authoritative Ying Zheng Unity EditMode hero acceptance fixture as a scheduled regression baseline.",
      "scope": [
        "unity-editmode",
        "moba-hero-acceptance",
        "moba-yingzheng",
        "scene-contracts",
        "authoritative-artifacts"
      ],
      "requiredBefore": [
