<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit</RootNamespace>
    <AssemblyName>AbilityKit.World.ECS</AssemblyName>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- 引用 Packages 目录下的源码 (排除 EntityWorld.cs 和 asmdef) -->
  <ItemGroup>
    <Compile Include="../../Unity/Packages/com.abilitykit.world.ecs/Runtime/**/*.cs" 
             Exclude="../../Unity/Packages/com.abilitykit.world.ecs/Runtime/**/*.asmdef;
                     ../../Unity/Packages/com.abilitykit.world.ecs/Runtime/AbilityKit.World.ECS/Impl/EntityWorld.cs" />
  </ItemGroup>

  <!-- 本地 .NET 版本文件 -->
  <ItemGroup>
    <Compile Include="Impl/EntityWorld.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/AbilityKit.Core/AbilityKit.Core.csproj" />
    <ProjectReference Include="../../src/AbilityKit.Diagnostics/AbilityKit.Diagnostics.csproj" />
  </ItemGroup>

</Project>
