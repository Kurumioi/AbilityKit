<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <ImplicitUsings>false</ImplicitUsings>
    <Nullable>disable</Nullable>
    <RootNamespace>Svelto</RootNamespace>
    <AssemblyName>AbilityKit.ThirdParty.Svelto</AssemblyName>
    <LangVersion>10</LangVersion>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/*.cs"
             Exclude="../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/*.asmdef;../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/Editor/**/*.cs;../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/Unity/**/*.cs;../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/obj/**/*.cs;../../Unity/Packages/com.abilitykit.thirdparty.svelto/Runtime/**/bin/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Memory" Version="4.5.5" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.0.0" />
  </ItemGroup>

</Project>
