<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit</RootNamespace>
    <AssemblyName>AbilityKit.Record.MemoryPack</AssemblyName>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- 排除 Unity 相关文件 -->
  <ItemGroup>
    <Compile Include="../../Unity/Packages/com.abilitykit.record.memorypack/Runtime/**/*.cs"
             Exclude="../../Unity/Packages/com.abilitykit.record.memorypack/Runtime/**/*.asmdef" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/AbilityKit.Core/AbilityKit.Core.csproj" />
    <ProjectReference Include="../../src/AbilityKit.Record/AbilityKit.Record.csproj" />
    <ProjectReference Include="../../src/AbilityKit.World.ECS/AbilityKit.World.ECS.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MemoryPack" Version="1.21.0" />
  </ItemGroup>

</Project>
