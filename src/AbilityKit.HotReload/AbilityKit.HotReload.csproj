<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit</RootNamespace>
    <AssemblyName>AbilityKit.HotReload</AssemblyName>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- 排除 Unity 相关文件 -->
  <ItemGroup>
    <Compile Include="../../Unity/Packages/com.abilitykit.hotreload/Runtime/**/*.cs" 
             Exclude="../../Unity/Packages/com.abilitykit.hotreload/Runtime/**/*.asmdef;
                     ../../Unity/Packages/com.abilitykit.hotreload/Runtime/HotReload/ConfigReloadDebugListener.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/AbilityKit.Core/AbilityKit.Core.csproj" />
    <ProjectReference Include="../../src/AbilityKit.World.DI/AbilityKit.World.DI.csproj" />
    <ProjectReference Include="../../src/AbilityKit.World.Entitas/AbilityKit.World.Entitas.csproj" />
  </ItemGroup>

</Project>
