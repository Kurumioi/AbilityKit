<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit.Pipeline</RootNamespace>
    <AssemblyName>AbilityKit.Pipeline</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <DefineConstants>$(DefineConstants);UNITY_EDITOR</DefineConstants>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../AbilityKit.Core/AbilityKit.Core.csproj" />
  </ItemGroup>

  <!-- 引用 Packages 目录下的源码（排除 Pipeline.cs，使用本地版本） -->
  <ItemGroup>
    <Compile Include="../../Unity/Packages/com.abilitykit.pipeline/Runtime/**/*.cs" Exclude="../../Unity/Packages/com.abilitykit.pipeline/Runtime/Pipeline.cs" />
    <Compile Include="../../Unity/Packages/com.abilitykit.pipeline/Editor/Debug/**/*.cs" />
  </ItemGroup>

</Project>
