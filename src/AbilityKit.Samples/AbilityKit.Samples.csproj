<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit.Samples</RootNamespace>
    <AssemblyName>AbilityKit.Samples</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Reference Samples Projects -->
  <ItemGroup>
    <ProjectReference Include="..\AbilityKit.Samples.Abstractions\AbilityKit.Samples.Abstractions.csproj" />
    <ProjectReference Include="..\AbilityKit.Samples.Logic\AbilityKit.Samples.Logic.csproj" />
  </ItemGroup>

  <!-- Analyzer 约束检查 -->
  <ItemGroup>
    <Analyzer Include="$(MSBuildThisFileDirectory)..\AbilityKit.Analyzer\bin\$(Configuration)\AbilityKit.Analyzer.dll" />
  </ItemGroup>
</Project>
