{
  "AbilityKit": {
    "Orleans": {
      "ClusterId": "abilitykit-dev",
      "ServiceId": "abilitykit-orleans",
      "GatewayPort": 30000
    },
    "Logging": {
      "MinimumLevel": "Debug",
      "MicrosoftLevel": "Warning",
      "HostingLifetimeLevel": "Information",
      "OrleansLevel": "Information",
      "ApplicationLevel": "Debug"
    },
    "Gateway": {
      "Http": {
        "Scheme": "http",
        "Host": "localhost",
        "Port": 5001,
        "PathBase": ""
      },
      "Tcp": {
        "Enabled": true,
        "Host": "0.0.0.0",
        "Port": 4000,
        "MaxFrameLength": 1048576,
        "RequestTimeoutMs": 5000
      }
    }
  }
}
